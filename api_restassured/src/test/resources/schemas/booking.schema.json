{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": [
    "id",
    "empId",
    "journeyType",
    "inventoryId",
    "state",
    "seatIds",
    "amountPaise",
    "refundable",
    "holdExpiresAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "pnr": {
      "type": [
        "string",
        "null"
      ]
    },
    "empId": {
      "type": "string",
      "minLength": 1
    },
    "journeyType": {
      "type": "string",
      "enum": [
        "bus",
        "flight"
      ]
    },
    "inventoryId": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": [
        "HELD",
        "CONFIRMED",
        "REFUNDED"
      ]
    },
    "seatIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "amountPaise": {
      "type": "integer",
      "minimum": 0
    },
    "refundable": {
      "type": "boolean"
    },
    "holdExpiresAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}